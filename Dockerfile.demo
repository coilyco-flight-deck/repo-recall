# syntax=docker/dockerfile:1.7
#
# Public demo of repo-recall. Boots with REPO_RECALL_DEMO=true against a
# tree of synthetic git repos and synthetic Claude Code session JSONLs, so
# anyone can `docker run` it without exposing their own session history or
# repos. Mutating endpoints (push, pull, clone, push-notification subscribe)
# return 403; the dashboard, search, and refresh stay live.
#
# This image is built and pushed to ghcr.io/coilysiren/repo-recall-demo by
# .github/workflows/demo-image.yml on every push to main.

# ---- Stage 1: build the release binary ------------------------------------ #
FROM rust:1-slim-bookworm AS builder

WORKDIR /src
RUN apt-get update \
 && apt-get install -y --no-install-recommends git pkg-config \
 && rm -rf /var/lib/apt/lists/*

# Cache crate downloads + a warmup build between source changes. We could
# extract this into a separate stage with cargo-chef, but the image only
# rebuilds on push-to-main and the win is small.
COPY Cargo.toml Cargo.lock build.rs ./
COPY src ./src
COPY static ./static

# build.rs prefers $REPO_RECALL_VERSION over `git describe`; pass a stable
# value so the binary doesn't claim a stale tag during a fresh container build.
ARG REPO_RECALL_VERSION=demo
ENV REPO_RECALL_VERSION=$REPO_RECALL_VERSION

RUN cargo build --release --locked \
 && strip target/release/repo-recall

# ---- Stage 2: runtime ---------------------------------------------------- #
FROM debian:bookworm-slim AS runtime

# git is needed at runtime - commits.rs shells out to it for each scanned
# repo. bash drives the fixture-build entrypoint. ca-certificates is here so
# any future https-using subcommand works; it's a few MB and avoids surprise.
RUN apt-get update \
 && apt-get install -y --no-install-recommends git bash ca-certificates \
 && rm -rf /var/lib/apt/lists/* \
 && useradd --create-home --shell /usr/sbin/nologin --uid 1000 demo

COPY --from=builder /src/target/release/repo-recall /usr/local/bin/repo-recall
COPY static /demo/static
COPY fixtures /demo/fixtures
COPY scripts/build-fixture-repos.sh /demo/scripts/build-fixture-repos.sh
COPY scripts/render-session-fixtures.sh /demo/scripts/render-session-fixtures.sh
COPY scripts/demo-entrypoint.sh /demo/scripts/demo-entrypoint.sh
RUN chmod +x /demo/scripts/*.sh

# render-session-fixtures.sh resolves its source dir relative to itself
# (../fixtures/sessions). Mirror that layout so the script doesn't need
# any container-specific tweaks.
RUN mkdir -p /demo/repos /demo/sessions \
 && chown -R demo:demo /demo

USER demo
WORKDIR /demo

# Inside the container, 0.0.0.0 is the only address that's reachable from
# the host's `docker run -p ...` mapping. The "loopback only" rail in
# CLAUDE.md is about a real machine; the access boundary here is the
# container's network namespace + whatever ports the user publishes.
ENV REPO_RECALL_DEMO=true \
    REPO_RECALL_HOST=0.0.0.0 \
    REPO_RECALL_PORT=7777 \
    REPO_RECALL_CWD=/demo/repos \
    REPO_RECALL_SESSIONS_DIR=/demo/sessions \
    REPO_RECALL_STATIC=/demo/static \
    REPO_RECALL_DEPTH=2 \
    REPO_RECALL_REFRESH_INTERVAL_SECS=0 \
    REPO_RECALL_DB=/tmp/repo-recall-demo.sqlite \
    RUST_LOG=info,repo_recall=info

EXPOSE 7777

HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD bash -c '</dev/tcp/127.0.0.1/7777' || exit 1

ENTRYPOINT ["/demo/scripts/demo-entrypoint.sh"]
