# repo-recall web: static React SPA served by Caddy. TLS is terminated
# upstream (tailscale-operator ts-proxy on the tailnet); this server speaks
# plain HTTP on the container port (default 8080).
#
# The Rust API + MCP host runs in a sibling container on :7777. In the k3s
# deploy both containers share a Pod, so the API is reachable at
# localhost:7777. In local docker-compose the service is named `api` and
# Docker's bridge DNS resolves it. $API_UPSTREAM overrides the default.

:{$PORT:8080} {
    root * /usr/share/caddy

    encode zstd gzip

    # JSON API + MCP host live on the sibling container. Path-match the
    # three surfaces the Rust binary owns; everything else falls through to
    # the SPA + try_files fallback below.
    @api {
        path /api/* /openapi.json /mcp /mcp/*
    }
    reverse_proxy @api {$API_UPSTREAM:localhost:7777}

    # Hashed bundle filenames are immutable; cache them aggressively.
    @hashed {
        path_regexp hashed ^/.+\.[0-9a-f]{8,}\..+$
    }
    header @hashed Cache-Control "public, max-age=31536000, immutable"

    # index.html must revalidate so fresh deploys land immediately.
    @html {
        path *.html
    }
    header @html Cache-Control "no-cache"

    # Basic security headers.
    header {
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    # SPA fallback: unknown paths serve index.html so client-side routing
    # works without server-side route definitions.
    try_files {path} /index.html
    file_server

    # Liveness/readiness endpoint for k8s probes.
    handle /healthz {
        respond "ok" 200
    }

    log {
        output stdout
        format console
    }
}
