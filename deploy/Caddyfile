# repo-recall web: static React SPA served by Caddy. TLS is terminated
# upstream by traefik + cert-manager in the k3s cluster; this server speaks
# plain HTTP on the container port (default 8080) and trusts the ingress.
#
# Sibling container serves the JSON API + MCP host at 127.0.0.1:7777 in the
# Rust binary. The ingress routes /api, /openapi.json, and /mcp directly to
# that container; this Caddyfile only knows about the static bundle.

:{$PORT:8080} {
    root * /usr/share/caddy

    encode zstd gzip

    # Hashed bundle filenames are immutable; cache them aggressively.
    @hashed {
        path_regexp hashed ^/.+\.[0-9a-f]{8,}\..+$
    }
    header @hashed Cache-Control "public, max-age=31536000, immutable"

    # index.html must revalidate so fresh deploys land immediately.
    @html {
        path *.html
    }
    header @html Cache-Control "no-cache"

    # Basic security headers.
    header {
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    # SPA fallback: unknown paths serve index.html so client-side routing
    # works without server-side route definitions.
    try_files {path} /index.html
    file_server

    # Liveness/readiness endpoint for k8s probes.
    handle /healthz {
        respond "ok" 200
    }

    log {
        output stdout
        format console
    }
}
